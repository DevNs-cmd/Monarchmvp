generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  FOUNDER
  INVESTOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
  BLACKLISTED
}

enum InterestStatus {
  PENDING
  MUTUAL
  DECLINED
}

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String           @unique
  role            Role             @default(FOUNDER)
  verified        Boolean          @default(false)
  status          UserStatus       @default(ACTIVE)
  tokenVersion    Int              @default(0)
  suspendedAt     DateTime?
  blacklistedAt   DateTime?
  blacklistReason String?
  linkedinUrl     String?
  inviteCodeUsed  String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  founderProfile  FounderProfile?
  investorProfile InvestorProfile?
  auditLogs       AuditLog[]
  activityLogs    ActivityLog[]
  payments        Payment[]
  messages        Message[]
  watchlists      Watchlist[]
  agreements      Agreement[]
  inviteId        String?          @unique
  inviteUsed      Invite?          @relation("InviteUsage", fields: [inviteId], references: [id])
  otpTokens       OtpToken[]
}

model Invite {
  id        String   @id @default(cuid())
  code      String   @unique
  role      Role
  used      Boolean  @default(false)
  usedBy    User?    @relation("InviteUsage")
  createdAt DateTime @default(now())
}

model FounderProfile {
  id                           String                @id @default(cuid())
  user                         User                  @relation(fields: [userId], references: [id])
  userId                       String                @unique
  companyName                  String
  stage                        String
  capitalAsk                   Float
  valuation                    Float?
  deckUrl                      String?
  deckVersion                  Int                   @default(1)
  monarchIndex                 Float?
  certifiedStatus              CertifiedStatus       @default(PENDING)
  certifiedUntil               DateTime?
  certificationId              String?               @unique
  successFeeAgreedAt           DateTime?
  advisoryEquityAcknowledgedAt DateTime?
  status                       String                @default("UNDER_REVIEW")
  summary                      String?
  metrics                      Json?
  financials                   Json?
  capTable                     Json?
  riskDisclosures              Json?
  kycStatus                    String                @default("PENDING")
  startup                      Startup?
  indexHistory                 MonarchIndexHistory[]
  certifications               CertificationRecord[]
}

model InvestorProfile {
  id                      String                @id @default(cuid())
  user                    User                  @relation(fields: [userId], references: [id])
  userId                  String                @unique
  investmentRange         String
  organization            String?
  investorType            String?
  sectors                 String[]
  stages                  String[]
  region                  String
  capitalMin              Float                 @default(0)
  capitalMax              Float                 @default(0)
  capitalRangeMin         Float?
  capitalRangeMax         Float?
  sectorPrefs             String[]              @default([])
  stagePrefs              String[]              @default([])
  ndaSigned               Boolean               @default(false)
  ndaSignedAt             DateTime?
  verified                Boolean               @default(false)
  kycStatus               String                @default("PENDING")
  accreditationStatus     String                @default("PENDING")
  accreditationVerifiedAt DateTime?
  interests               Interest[]
  introductionRequests    IntroductionRequest[]
}

model Startup {
  id                   String                @id @default(cuid())
  founder              FounderProfile        @relation(fields: [founderId], references: [id])
  founderId            String                @unique
  industry             String
  stage                String
  capitalAsk           Float
  region               String                @default("Global")
  monarchIndex         Float?
  interests            Interest[]
  introductionRequests IntroductionRequest[]
  dealRooms            DealRoom[]
}

model Interest {
  id                String          @id @default(cuid())
  investor          InvestorProfile @relation(fields: [investorId], references: [id])
  investorId        String
  startup           Startup         @relation(fields: [startupId], references: [id])
  startupId         String
  investorInterest  Boolean         @default(false)
  founderInterest   Boolean         @default(false)
  status            InterestStatus  @default(PENDING)
  introRequestedAt  DateTime?
  introStatus       String?
  mutualConfirmedAt DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([investorId, startupId])
}

model IntroductionRequest {
  id         String          @id @default(cuid())
  investor   InvestorProfile @relation(fields: [investorId], references: [id])
  investorId String
  startup    Startup         @relation(fields: [startupId], references: [id])
  startupId  String
  status     String          @default("PENDING")
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([investorId, startupId])
}

model DealRoom {
  id                  String         @id @default(cuid())
  startup             Startup        @relation(fields: [startupId], references: [id])
  startupId           String
  investorId          String
  unlocked            Boolean        @default(false)
  stage               DealStage      @default(INTRODUCTION)
  ndaConfirmed        Boolean        @default(false)
  successFeeTriggered Boolean        @default(false)
  lastActivityAt      DateTime?
  messages            Message[]
  documents           DealDocument[]
  meetings            Meeting[]
  events              DealEvent[]
  introducedAt        DateTime       @default(now())
  fundedAt            DateTime?
  fundedAmount        Float?
  successFeeRate      Float          @default(0.025)
  successFeeAmount    Float?
  successFeeStatus    String         @default("NOT_TRIGGERED")
  createdAt           DateTime       @default(now())

  @@unique([startupId, investorId])
}

model Message {
  id               String   @id @default(cuid())
  dealRoom         DealRoom @relation(fields: [dealRoomId], references: [id])
  dealRoomId       String
  sender           User     @relation(fields: [senderId], references: [id])
  senderId         String
  encryptedContent String
  createdAt        DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  action    String
  entity    String
  timestamp DateTime @default(now())
}

model Payment {
  id                    String      @id @default(cuid())
  user                  User        @relation(fields: [userId], references: [id])
  userId                String
  amount                Float
  currency              String      @default("USD")
  type                  PaymentType
  stripeSessionId       String?
  stripePaymentIntentId String?
  status                String      @default("pending")
  receiptUrl            String?
  createdAt             DateTime    @default(now())
}

model AccessRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  linkedin  String
  role      Role
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
}

model MigMarket {
  id                   String   @id @default(cuid())
  ticker               String   @unique
  migScore             Int
  riskIndex            Int
  recommendation       String
  allocationSuggestion String
  rationale            String[]
  createdAt            DateTime @default(now())
}

model MIGSignal {
  id             String    @id @default(cuid())
  ticker         String
  companyName    String
  sector         String
  migScore       Float
  riskIndex      Float
  recommendation String
  timeHorizon    String
  rationale      String[]
  suggestedAlloc Float
  approvedAt     DateTime?
  approvedBy     String?
  publishedAt    DateTime?
  isPublished    Boolean   @default(false)
  createdAt      DateTime  @default(now())
}

model Watchlist {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  ticker    String
  createdAt DateTime @default(now())

  @@unique([userId, ticker])
}

model MonarchIndexHistory {
  id               String         @id @default(cuid())
  founderProfile   FounderProfile @relation(fields: [founderProfileId], references: [id])
  founderProfileId String
  score            Float
  version          Int            @default(1)
  breakdown        Json?
  setBy            String         @default("SYSTEM")
  createdAt        DateTime       @default(now())
}

model OtpToken {
  id        String    @id @default(cuid())
  user      User?     @relation(fields: [userId], references: [id])
  userId    String?
  email     String?
  code      String?
  hashedOtp String?
  expiresAt DateTime
  used      Boolean   @default(false)
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([email])
  @@index([email, code, used])
}

model ActivityLog {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  action    String
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())
}

model CertificationRecord {
  id               String         @id @default(cuid())
  founderProfile   FounderProfile @relation(fields: [founderProfileId], references: [id])
  founderProfileId String
  stage            Int
  status           String
  reviewedBy       String?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model DealDocument {
  id         String   @id @default(cuid())
  dealRoom   DealRoom @relation(fields: [dealRoomId], references: [id])
  dealRoomId String
  uploadedBy String
  filename   String
  s3Key      String
  size       Int
  createdAt  DateTime @default(now())
}

model Meeting {
  id            String   @id @default(cuid())
  dealRoom      DealRoom @relation(fields: [dealRoomId], references: [id])
  dealRoomId    String
  scheduledAt   DateTime
  format        String
  monarchHosted Boolean  @default(true)
  joinUrl       String?
  createdAt     DateTime @default(now())
}

model Agreement {
  id          String          @id @default(cuid())
  user        User            @relation(fields: [userId], references: [id])
  userId      String
  type        AgreementType
  version     String          @default("2026.1")
  status      AgreementStatus @default(PENDING)
  signerName  String?
  acceptedAt  DateTime?
  acceptedIp  String?
  contentHash String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([userId, type, version])
  @@index([userId, status])
}

model DealEvent {
  id         String     @id @default(cuid())
  dealRoom   DealRoom   @relation(fields: [dealRoomId], references: [id])
  dealRoomId String
  type       String
  actorId    String
  fromStage  DealStage?
  toStage    DealStage?
  metadata   Json?
  createdAt  DateTime   @default(now())

  @@index([dealRoomId, createdAt])
}

enum PaymentType {
  SCREENING_FEE
  BOARDROOM_ACCESS
  ALGO_ACCESS
  CUSTOM_REPORT
}

enum CertifiedStatus {
  PENDING
  STAGE_1
  STAGE_2
  STAGE_3
  STAGE_4
  CERTIFIED
  REVOKED
}

enum DealStage {
  INTRODUCTION
  NDA_SIGNED
  DOCUMENTS_EXCHANGED
  TERM_SHEET
  FUNDED
}

enum AgreementType {
  PLATFORM_TERMS
  INVESTOR_NDA
  SUCCESS_FEE
  ADVISORY_EQUITY
  DATA_ROOM_CONFIDENTIALITY
}

enum AgreementStatus {
  PENDING
  ACCEPTED
  SUPERSEDED
  REVOKED
}
